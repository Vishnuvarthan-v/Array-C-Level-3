#include<stdio.h>

int main()
{
  int a,sumev=0,sumodd=0;
  scanf("%d", &a);

  int s[a];

  for(int i=0;i<a;i++)
  {
    scanf("%d", &s[i]);
    }
    for(int j=0;j<a;j++)
    {
    if(s[j]%2==0){
      sumev+=s[j];
    }
    else{
      sumodd+=s[j];
    }
    }

    printf("\nEven Sum = %d", sumev);
    printf("\nOdd Sum = %d", sumodd);

  return 0;
}


Input:
5
1 2 3 4 5

Expected Output:
Even Sum = 6
Odd Sum = 9
