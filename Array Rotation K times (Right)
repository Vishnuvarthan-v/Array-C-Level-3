#include <stdio.h>

int main() 
{
    int a[100],n,i,temp,j,rot;
    scanf("%d", &n);
    
    for(i=0;i<n;i++)
    {
        scanf("%d", &a[i]);
    }
    
    scanf("%d", &rot);
    
    for(i=0;i<rot;i++)
    {
        temp = a[0];
        
        for(j=0;j<n-1;j++)
        {
            a[j]=a[j+1];
        }
        a[n-1]=temp;
    }
    
    for(i=0;i<n;i++)
    {
        printf("%d ", a[i]);
    }
    return 0;
}

Input:5
1 2 3 4 5
2
Output:
3 4 5 1 2
